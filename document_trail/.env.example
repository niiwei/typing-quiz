# 敲脑壳 MindPop 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置
# ============================================

# MySQL 服务器地址
# 本地开发：localhost
# 连接云端：your_server_ip
MYSQL_HOST=localhost

# MySQL 端口（默认3306）
MYSQL_PORT=3306

# 数据库名称
MYSQL_DATABASE=typing_quiz

# 数据库用户名
MYSQL_USERNAME=typingquiz

# 数据库密码（生产环境请使用强密码）
MYSQL_PASSWORD=your_secure_password

# ============================================
# 应用配置
# ============================================

# 服务器端口（默认8080）
SERVER_PORT=8080

# JWT 密钥（生产环境请更换为随机生成的强密钥）
JWT_SECRET=your_jwt_secret_key_here

# JWT 有效期（毫秒，默认24小时）
JWT_EXPIRATION=86400000

# ============================================
# 安全配置
# ============================================

# 是否启用 HTTPS（生产环境建议启用）
SSL_ENABLED=false

# SSL 密钥库路径（启用HTTPS时配置）
# SSL_KEY_STORE=keystore.p12

# SSL 密钥库密码
# SSL_KEY_STORE_PASSWORD=your_keystore_password

# 允许的 CORS 域名（生产环境应限制）
# 多个域名用逗号分隔，如：http://localhost:8080,https://yourdomain.com
CORS_ALLOWED_ORIGINS=*

# ============================================
# 日志配置
# ============================================

# 日志级别：DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# 应用日志级别
APP_LOG_LEVEL=DEBUG

# Spring Web 日志级别
WEB_LOG_LEVEL=INFO

# ============================================
# 缓存配置（可选）
# ============================================

# 是否启用 Redis 缓存
REDIS_ENABLED=false

# Redis 服务器地址
# REDIS_HOST=localhost

# Redis 端口
# REDIS_PORT=6379

# ============================================
# 邮件配置（可选，用于密码重置）
# ============================================

# SMTP 服务器
# MAIL_HOST=smtp.example.com

# SMTP 端口
# MAIL_PORT=587

# 邮箱用户名
# MAIL_USERNAME=noreply@example.com

# 邮箱密码
# MAIL_PASSWORD=your_mail_password

# 发件人显示名称
# MAIL_FROM_NAME=敲脑壳 MindPop

# ============================================
# 注意事项
# ============================================

# 1. 此文件为模板文件，实际使用时：
#    - 复制本文件为 .env
#    - 填入实际的配置值
#    - 确保 .env 文件已添加到 .gitignore，不提交到版本控制
#
# 2. 生产环境配置建议：
#    - 使用强密码
#    - 启用 HTTPS
#    - 限制 CORS 域名
#    - 禁用 SQL 日志输出
#    - 使用独立的 Redis 缓存
#
# 3. 本地开发配置建议：
#    - 可以使用简单的密码
#    - 启用 DEBUG 日志方便调试
#    - 允许所有 CORS 请求
