# 敲脑壳 MindPop 环境变量配置模板
# 复制此文件为 .env 并填写真实值，.env 文件不会被提交到Git

# ============================================
# 数据库配置
# ============================================
# MySQL服务器地址（本地开发可填localhost，远程开发填服务器IP）
MYSQL_HOST=localhost

# MySQL用户名
MYSQL_USER=typingquiz

# MySQL密码（必填）
MYSQL_PASSWORD=your_mysql_password_here

# ============================================
# JWT认证配置
# ============================================
# JWT密钥（生产环境必须修改，建议使用随机生成的长字符串）
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# ============================================
# 可选配置
# ============================================
# 应用端口（默认8080）
# SERVER_PORT=8080

# 日志级别（DEBUG/INFO/WARN/ERROR）
# LOG_LEVEL=INFO
